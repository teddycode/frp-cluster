# Address of any existing control plane node. For the first node, set it to NODE_CONTROL_URL.
BOOTSTRAP_CONTROL_URL=http://CONTROL_PLANE_IP:8080

# Public Web/API URL exposed by this proxy node.
NODE_CONTROL_URL=http://THIS_NODE_PUBLIC_IP:8080

# One-time join token created from any control plane Web page or CLI.
# For the first node, leave it empty or set auto to create one locally.
JOIN_TOKEN=auto

# Unique node ID in the cluster.
NODE_ID=edge-a

# Public frps address clients can connect to.
PUBLIC_ADDR=THIS_NODE_PUBLIC_IP

# frps ports.
BIND_PORT=7000

# Business remote ports clients may expose on this frps.
# Use comma-separated ranges or single ports, for example: 11000-12000,12080
ALLOW_PORTS=11000-12000

VHOST_HTTP_PORT=0
VHOST_HTTPS_PORT=0

# Local control plane listen address and data file.
CONTROL_LISTEN=:8080
CONTROL_DATA=/var/lib/frp-cluster/cluster.json

# Stable DNS name users connect to, for example ssh.buaadcl.tech.
# Leave empty until the DNS name is allocated.
PUBLIC_ENTRY_HOST=

# Optional executable hook called before a manual client switch.
# The hook receives FRP_CLUSTER_DNS_HOST and FRP_CLUSTER_DNS_TARGET_IP.
DNS_UPDATE_HOOK=

# React frontend static directory installed by proxy-node-join.sh.
WEB_DIR=/usr/local/share/frp-cluster/web

# Admin password file for the control panel login.
# Set ADMIN_PASSWORD during first install to create this file, then remove it from env.
ADMIN_PASSWORD_FILE=/etc/frp-cluster/admin-password
ADMIN_PASSWORD=
AUTH_CONFIG_FILE=/etc/frp-cluster/auth.env
ALIDNS_CONFIG_FILE=/etc/frp-cluster/alidns.env

# Optional node metadata.
REGION=
TAGS=

# Agent network status update interval and active bandwidth probe size. Use 0 probe size to disable active probing.
AGENT_INTERVAL=30s
PROBE_SIZE=262144
FRPS_DASHBOARD_URL=http://127.0.0.1:7500
