# Address of any existing control plane node. For the first node, set it to NODE_CONTROL_URL.
BOOTSTRAP_CONTROL_URL=http://CONTROL_PLANE_IP:8080

# Public Web/API URL exposed by this proxy node.
NODE_CONTROL_URL=http://THIS_NODE_PUBLIC_IP:8080

# One-time join token created from any control plane Web page or CLI.
# For the first node, leave it empty or set auto to create one locally.
JOIN_TOKEN=auto

# Unique node ID in the cluster.
NODE_ID=edge-a

# Public frps address clients can connect to.
PUBLIC_ADDR=THIS_NODE_PUBLIC_IP

# frps ports.
BIND_PORT=7000

# Business remote ports clients may expose on this frps.
# Use comma-separated ranges or single ports, for example: 11000-12000,12080
ALLOW_PORTS=11000-12000

VHOST_HTTP_PORT=0
VHOST_HTTPS_PORT=0

# Local control plane listen address and data file.
CONTROL_LISTEN=:8080
CONTROL_DATA=/var/lib/frp-cluster/cluster.json

# Optional node metadata.
REGION=
TAGS=

# Agent active bandwidth probe size. Use 0 to disable.
PROBE_SIZE=262144
