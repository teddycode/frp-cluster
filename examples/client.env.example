# Address of any proxy node Web/API control plane.
CONTROL_URL=http://CONTROL_PLANE_IP:8080

# Client identity shown in the management UI.
CLIENT_ID=app-1

# failover starts the best node by default. Use aggregate to run one frpc per node.
MODE=failover
LIMIT=1

# Refresh interval and drain time for switching frpc processes.
INTERVAL=30s
FAILOVER_INTERVAL=10s
DRAIN_TIMEOUT=30s

# Repeat business proxies as semicolon-separated specs:
# name:type:localIP:localPort:remotePort
PROXIES='web:tcp:127.0.0.1:8080:18080'

WORK_DIR=/var/lib/frp-cluster/frpc.d
FRPC_BIN=/usr/local/bin/frpc
