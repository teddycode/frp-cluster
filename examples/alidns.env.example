# Aliyun DNS credentials used by:
#   frp-cluster dns alidns-update --config /etc/frp-cluster/alidns.env
#
# Do not commit the real file.
ALIDNS_ACCESS_KEY_ID=
ALIDNS_ACCESS_KEY_SECRET=

# Base DNS zone hosted in Alibaba Cloud DNS.
ALIDNS_DOMAIN_NAME=buaadcl.tech

# Optional fixed RR. Leave empty to derive it from FRP_CLUSTER_DNS_HOST.
# For ssh-proxy.buaadcl.tech this is ssh-proxy.
ALIDNS_RR=

ALIDNS_RECORD_TYPE=A
ALIDNS_TTL=600
ALIDNS_ENDPOINT=alidns.cn-hangzhou.aliyuncs.com
ALIDNS_LINE=default
