[Unit]
Description=frp-cluster local control plane
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/frp-cluster/node.env
ExecStart=/usr/local/bin/frp-cluster server --listen ${CONTROL_LISTEN} --data ${CONTROL_DATA} --public-url ${NODE_CONTROL_URL} --peer ${BOOTSTRAP_CONTROL_URL}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
