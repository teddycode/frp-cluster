# Copy this file to .env and fill real values locally.
# .env is ignored by git.

# Shared frp authentication token used in generated frps/frpc configs.
# Generate with: openssl rand -base64 32
FRP_CLUSTER_AUTH_TOKEN=

# Initial admin bootstrap password for binding TOTP.
# Prefer a long random value. Remove it after TOTP is configured if you use a password file instead.
FRP_CLUSTER_ADMIN_PASSWORD=
FRP_CLUSTER_ADMIN_PASSWORD_FILE=

# Runtime secret/config files. These files also contain sensitive data and should stay outside git.
FRP_CLUSTER_AUTH_CONFIG_FILE=/etc/frp-cluster/auth.env
FRP_CLUSTER_ALIDNS_CONFIG_FILE=/etc/frp-cluster/alidns.env
FRP_CLUSTER_NODE_ENV_FILE=/etc/frp-cluster/node.env

# AliDNS credentials used by: frp-cluster dns alidns-update
ALIDNS_ACCESS_KEY_ID=
ALIDNS_ACCESS_KEY_SECRET=
ALIDNS_DOMAIN_NAME=
ALIDNS_RR=
ALIDNS_RECORD_TYPE=A
ALIDNS_TTL=600
ALIDNS_ENDPOINT=alidns.cn-hangzhou.aliyuncs.com
ALIDNS_LINE=default
